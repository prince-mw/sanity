# Next.js Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# SANITY CMS CONFIGURATION
# ===========================================

# Sanity Project ID and Dataset
NEXT_PUBLIC_SANITY_PROJECT_ID=u10im6di
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API Token (for server-side queries with draft access)
# Create at: https://manage.sanity.io → Project → API → Tokens
SANITY_API_TOKEN=

# Preview secret - must match SANITY_STUDIO_PREVIEW_SECRET in Studio
SANITY_PREVIEW_SECRET=preview-secret-key

# Webhook secret for Sanity webhook verification
SANITY_WEBHOOK_SECRET=

# ===========================================
# WEBSITE URLS
# ===========================================

# Public URL of the website
# Development: http://localhost:3000
# Staging: https://stg.movingwalls.com
# Production: https://movingwalls.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
