# Sanity Studio Environment Variables

# Preview URL - your Next.js app URL
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000

# Preview secret - must match SANITY_PREVIEW_SECRET in Next.js
SANITY_STUDIO_PREVIEW_SECRET=preview-secret-key

# Staging deployment configuration
# URL for the Moving Walls staging environment
SANITY_STUDIO_STAGING_URL=https://manage-stg.movingwalls.com/test

# API key for staging authentication (get this from your IT team)
SANITY_STUDIO_STAGING_API_KEY=
